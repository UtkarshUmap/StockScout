# Choose your LLM provider: "groq", "anthropic", or "mock"
# "mock" works without any API key (uses rule-based scoring + keyword sentiment)
LLM_PROVIDER=mock

# Groq - FREE, fast. Get key at: https://console.groq.com/keys
GROQ_API_KEY=

# Anthropic - Get key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=
